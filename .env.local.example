# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (.env.local ถูก gitignore แล้ว)

# ── Google OAuth ─────────────────────────────────────────────────────────────
# สร้างที่ https://console.cloud.google.com/apis/credentials
#   1. Create Credentials → OAuth client ID → Web application
#   2. Authorized redirect URI:
#        dev:  http://localhost:3000/api/auth/callback/google
#        prod: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ─────────────────────────────────────────────────────────────────
# สร้าง secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# URL ของแอป (prod ต้องตั้งเป็น https://<your-domain>)
NEXTAUTH_URL=http://localhost:3000

# ── App ──────────────────────────────────────────────────────────────────────
# สวิตช์หลัก: true = เปิด Google login + first-login claim + บังคับ identity ฝั่ง server
#             false/ไม่ตั้ง = โหมดเดิม (เลือกชื่อเองจาก dropdown ไม่ต้อง login)
AUTH_ENABLED=false
# ปิดฟังก์ชันจอง/ปล่อยที่นั่งชั่วคราว (ยังดูผังที่นั่งได้ปกติ) — false = ปิด, true/ไม่ตั้ง = เปิด
BOOKING_ENABLED=true
# จำกัด login เฉพาะ email domain นี้ (ตั้งเป็นค่าว่างเพื่อปิดการจำกัด — dev เท่านั้น)
ALLOWED_EMAIL_DOMAIN=ocean.co.th
# รายชื่อ admin คั่นด้วย comma — ถ้าเว้นว่าง หน้า /admin007 จะเปิดให้ทุกคน (dev เท่านั้น)
ADMIN_EMAILS=chatnarin.ak@ocean.co.th
